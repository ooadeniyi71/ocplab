{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClusterInstance Helm Values",
  "description": "Schema validation for ClusterInstance Helm chart values",
  "type": "object",
  "required": [
    "cluster",
    "clusterSpec",
    "network",
    "masterNodes",
    "workerNodes"
  ],
  "properties": {
    "cluster": {
      "type": "object",
      "required": ["name", "namespace", "environment"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]{0,61}[a-z0-9])?$",
          "description": "Cluster name (must be valid DNS subdomain)"
        },
        "namespace": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]{0,61}[a-z0-9])?$",
          "description": "Kubernetes namespace"
        },
        "environment": {
          "type": "string",
          "enum": ["development", "staging", "production"],
          "description": "Cluster environment"
        },
        "syncWave": {
          "type": ["string", "integer"],
          "description": "ArgoCD sync wave"
        }
      }
    },
    "clusterSpec": {
      "type": "object",
      "required": [
        "baseDomain",
        "clusterImageSetNameRef",
        "sshPublicKey"
      ],
      "properties": {
        "baseDomain": {
          "type": "string",
          "pattern": "^([a-zA-Z0-9]([a-zA-Z0-9\\-]{0,61}[a-zA-Z0-9])?\\.)+[a-zA-Z0-9]([a-zA-Z0-9\\-]{0,61}[a-zA-Z0-9])?$",
          "description": "Base domain for the cluster"
        },
        "networkType": {
          "type": "string",
          "enum": ["OpenShiftSDN", "OVNKubernetes"],
          "default": "OVNKubernetes",
          "description": "Cluster network type"
        },
        "holdInstallation": {
          "type": "boolean",
          "default": false,
          "description": "Hold cluster installation"
        },
        "clusterImageSetNameRef": {
          "type": "string",
          "description": "Reference to cluster image set"
        },
        "pullSecretName": {
          "type": "string",
          "description": "Name of pull secret"
        },
        "sshPublicKey": {
          "type": "string",
          "pattern": "^ssh-(rsa|ed25519|ecdsa-sha2-nistp256|ecdsa-sha2-nistp384|ecdsa-sha2-nistp521)\\s",
          "description": "SSH public key for cluster access"
        },
        "virtualIPs": {
          "type": "object",
          "required": ["api", "ingress"],
          "properties": {
            "api": {
              "type": "string",
              "format": "ipv4",
              "description": "API virtual IP address"
            },
            "ingress": {
              "type": "string",
              "format": "ipv4",
              "description": "Ingress virtual IP address"
            }
          }
        },
        "additionalNTPSources": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Additional NTP sources"
        }
      }
    },
    "network": {
      "type": "object",
      "required": ["cluster", "service", "machine"],
      "properties": {
        "cluster": {
          "type": "object",
          "required": ["cidr"],
          "properties": {
            "cidr": {
              "type": "string",
              "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$",
              "description": "Cluster network CIDR"
            },
            "hostPrefix": {
              "type": "integer",
              "minimum": 1,
              "maximum": 32,
              "default": 23,
              "description": "Host prefix for pod networks"
            }
          }
        },
        "service": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$"
          },
          "minItems": 1,
          "description": "Service network CIDRs"
        },
        "machine": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["cidr"],
            "properties": {
              "cidr": {
                "type": "string",
                "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$",
                "description": "Machine network CIDR"
              }
            }
          },
          "minItems": 1,
          "description": "Machine network CIDRs"
        }
      }
    },
    "networkDefaults": {
      "type": "object",
      "properties": {
        "interfaceName": {
          "type": "string",
          "description": "Network interface name"
        },
        "ipv4": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "prefixLength": {
              "type": "integer",
              "minimum": 1,
              "maximum": 32,
              "default": 22
            },
            "dhcp": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "dns": {
          "type": "object",
          "properties": {
            "servers": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "ipv4"
              }
            }
          }
        },
        "gateway": {
          "type": "object",
          "properties": {
            "address": {
              "type": "string",
              "format": "ipv4",
              "description": "Gateway IP address"
            },
            "routeTableId": {
              "type": "string",
              "description": "Route table ID"
            }
          }
        }
      }
    },
    "masterNodes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/node"
      },
      "minItems": 1,
      "maxItems": 5,
      "description": "Master/Control Plane nodes (typically 1, 3, or 5)"
    },
    "workerNodes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/node"
      },
      "minItems": 0,
      "description": "Worker nodes (can scale from 0 to many)"
    }
  },
  "definitions": {
    "node": {
      "type": "object",
      "required": [
        "name",
        "hostname",
        "bootMAC",
        "interfaceMAC",
        "ipAddress",
        "rootDevice"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]{0,61}[a-z0-9])?$",
          "description": "Node identifier"
        },
        "hostname": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]{0,61}[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]{0,61}[a-z0-9])?)*$",
          "description": "Node FQDN hostname"
        },
        "bootMAC": {
          "type": "string",
          "pattern": "^([0-9a-fA-F]{2}:){5}([0-9a-fA-F]{2})$",
          "description": "Boot MAC address"
        },
        "interfaceMAC": {
          "type": "string",
          "pattern": "^([0-9a-fA-F]{2}:){5}([0-9a-fA-F]{2})$",
          "description": "Network interface MAC address"
        },
        "ipAddress": {
          "type": "string",
          "format": "ipv4",
          "description": "Node IP address"
        },
        "rootDevice": {
          "type": "string",
          "pattern": "^/dev/[a-z]+[0-9]*$",
          "description": "Root device path"
        },
        "bootMode": {
          "type": "string",
          "enum": ["UEFI", "Legacy"],
          "default": "UEFI",
          "description": "Boot mode configuration"
        }
      }
    }
  }
}
