{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["cluster", "network", "sshPublicKey", "nodes"],
  "properties": {
    "cluster": {
      "type": "object",
      "required": ["name", "namespace", "baseDomain", "imageSetRef", "environment"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 },
        "baseDomain": { "type": "string", "minLength": 1 },
        "imageSetRef": { "type": "string", "minLength": 1 },
        "environment": { "type": "string", "minLength": 1 }
      }
    },
    "sshPublicKey": { "type": "string", "minLength": 1 },
    "network": {
      "type": "object",
      "required": ["apiVIP", "ingressVIP", "clusterNetwork", "serviceNetwork", "machineNetwork", "interfaceName", "gateway", "dns", "ntp"],
      "properties": {
        "apiVIP": { "type": "string", "minLength": 1 },
        "ingressVIP": { "type": "string", "minLength": 1 },
        "clusterNetwork": { "type": "string", "minLength": 1 },
        "serviceNetwork": { "type": "string", "minLength": 1 },
        "machineNetwork": { "type": "string", "minLength": 1 },
        "interfaceName": { "type": "string", "minLength": 1 },
        "gateway": { "type": "string", "minLength": 1 },
        "dns": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "ntp": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["hostName", "role", "bootMACAddress", "macAddress", "ipAddress"],
        "properties": {
          "hostName": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "enum": ["master", "worker"] },
          "bootMACAddress": { "type": "string", "minLength": 1 },
          "macAddress": { "type": "string", "minLength": 1 },
          "ipAddress": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
